# ===== StrategyHarvester secrets (TEMPLATE) =====
# Copy this file to ".env" and fill in your own values.

# --- Telegram (get from https://my.telegram.org) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# --- Telegram headless/CI session (Phase 1 content-intelligence watchlist) ---
# Only needed to run ingestion/telegram_reader.py's process_watchlist() with
# no terminal attached (e.g. the content_intelligence.yml GitHub Actions
# workflow). A Telethon StringSession generated ONCE from an already-
# authorized interactive login (see SUMMARY_PHASE1.md). Treat this like a
# password — anyone with it can read your Telegram account's messages.
TELEGRAM_SESSION_STRING=

# --- Claude API (AUTO extraction + Phase 2 rule parsing) ---
CLAUDE_API_KEY=

# --- Dashboard login (Phase 3 live management dashboard) ---
# Required — the dashboard refuses all access (fails closed) if this is
# empty. Pick any passphrase; it's compared as a plain shared secret (no
# separate username), gating a signed session cookie. Change it any time by
# editing this value and restarting oracle_dashboard.service.
DASHBOARD_PASSPHRASE=

# --- Claude CLI subscription auth (SUBSCRIPTION extraction mode, Phase 1) ---
# Only needed for headless runs (e.g. GitHub Actions) of the `claude` CLI
# used by extraction/strategy_extractor.py's SUBSCRIPTION mode (see
# config.json's "extraction_mode"). Not needed locally if `claude` is
# already logged in interactively on this machine.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Binance (Phase 2 backtesting; public data works without keys) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Telegram alert bot (Phase 3, REQUIRED for live alerts) ---
# 1) Create a bot via @BotFather and copy the token.
# 2) Send your bot any message, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id": ...}.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Twitter / X API (Phase 5, optional — scraping + sentiment) ---
# Bearer token alone is enough for read-only v2 endpoints.
X_BEARER_TOKEN=
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
